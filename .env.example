# Database connection URL (required to run the API).
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://username:password@127.0.0.1:5432/database

# Redis for the live kill stream (broadcaster). Omit to disable live streaming.
REDIS_URL=redis://localhost:6379

# Redis for the response/ESI cache layer. Omit to disable caching.
REDIS_CACHE_URL=redis://localhost:6379

# Contact-bearing User-Agent for ESI requests, per CCP API rules.
USER_AGENT=eve-killmap:backend/1.0.0 (your-contact@example.com)

# Secret token for GET /health/detail. If unset, that endpoint is disabled (404).
HEALTH_TOKEN=

# Log file path (defaults to ./backend.log).
LOG_FILE=backend.log

# Optional: overrides logging.level from config.yml.
# LOG_LEVEL=INFO

# Per-worker Prometheus metrics port. Set per systemd worker (e.g. METRICS_PORT=910%i).
# Overrides metrics.port from config.yml. Metrics are internal-only; firewall this port.
# METRICS_PORT=9109

# Set to False to bar this worker from becoming the live-stream broadcaster leader.
# It still follows and fans out kills to its WebSocket clients, but never tails the
# stream or refreshes sov. Default (unset) is True. Keep at least one worker eligible,
# or no worker tails kills:live and live streaming stops.
# LEADER_ELECTION=True
